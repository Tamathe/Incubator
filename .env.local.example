# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Do not commit real values here.

# Neon supplies both values when its Vercel Marketplace resource is connected.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Generate a 32+ character random secret and a bcrypt password hash.
JWT_SECRET=
ADMIN_PASSWORD_HASH=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
