# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — do not commit real values here.

# URL of the pitch-intake Cloudflare Worker (see worker/pitch-intake/README.md).
# Local dev:      http://localhost:8787
# Production:     https://pitch-intake.<your-cf-subdomain>.workers.dev
NEXT_PUBLIC_PITCH_WORKER_URL=

# Supabase project for the /ideas page (see docs/supabase/README.md).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
